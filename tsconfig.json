{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020"],
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "rewriteRelativeImportExtensions": true,
    "paths": {
      "@steer/types": ["./packages/types/src/index.ts"],
      "@steer/types/*": ["./packages/types/src/*"],
      "@steer/config": ["./packages/config/src/index.ts"],
      "@steer/config/*": ["./packages/config/src/*"],
      "@steer/ui": ["./packages/ui/src/index.ts"],
      "@steer/ui/*": ["./packages/ui/src/*"]
    }
  }
}
