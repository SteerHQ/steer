{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoiceAssistant",
  "version": "1.0.0",
  "identifier": "com.voiceassistant.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": {
        "language": "ru-RU"
      },
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "allowDowngrades": false
    },
    "shortDescription": "Голосовой помощник для Windows",
    "longDescription": "VoiceAssistant - утилита для захвата системного аудио, распознавания русской речи через OpenAI Whisper и предоставления кратких технических ответов через overlay-интерфейс.",
    "externalBin": [],
    "copyright": "Copyright (c) 2025 VoiceAssistant",
    "category": "Utility",
    "fileAssociations": [],
    "resources": []
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Voice Assistant Overlay",
        "width": 400,
        "height": 200,
        "resizable": false,
        "fullscreen": false,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "skipTaskbar": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {}
}
