{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@steer/types": ["../../packages/types/src/index.ts"],
      "@steer/types/*": ["../../packages/types/src/*"],
      "@steer/config": ["../../packages/config/src/index.ts"],
      "@steer/config/*": ["../../packages/config/src/*"],
      "@steer/ui": ["../../packages/ui/src/index.ts"],
      "@steer/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src-tauri"]
}
