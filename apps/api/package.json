{
  "name": "@steer/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch --env-file=../../.env src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run --env-file=../../.env dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@steer/types": "workspace:*",
    "groq-sdk": "^1.3.0",
    "hono": "^4.12.27"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
