{
  "name": "@steer/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch --env-file=../../.env src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run --env-file=../../.env dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.67",
    "@steer/types": "workspace:*",
    "ai": "^5.0.93",
    "better-sqlite3": "^12.4.1",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.10.6",
    "openai": "^6.9.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.2",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "drizzle-kit": "^0.31.7",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.9"
  }
}
