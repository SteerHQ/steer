{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "ignore": [
      "node_modules/**",
      ".next/**",
      "packages/ui/src/**/*.tsx",
      "packages/ui/src/**/*.ts",
      "packages/ui/src/**/*.css",
      "tooling/**/*",
      "apps/app/**/*.css",
      "dist/**",
      "build/**",
      ".git/**",
      "e2e/**",
      "*.test.ts"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "error",
        "noAssignInExpressions": "off",
        "noArrayIndexKey": "warn",
        "noDebugger": "warn"
      },
      "style": {
        "noNonNullAssertion": "warn",
        "useImportType": "error",
        "useTemplate": "warn",
        "useConst": "warn"
      },
      "a11y": {
        "useSemanticElements": "warn"
      },
      "security": {
        "noDangerouslySetInnerHtml": "warn"
      },
      "correctness": {
        "noUnusedVariables": {
          "level": "error"
        },
        "noUnusedImports": "error",
        "noUnusedFunctionParameters": "warn",
        "noUnreachableSuper": "error",
        "noChildrenProp": "off",
        "noUnreachable": "error",
        "noUndeclaredVariables": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "always"
    },
    "globals": ["Bun", "React"]
  },
  "css": {
    "parser": {
      "cssModules": false,
      "allowWrongLineComments": true
    }
  },
  "overrides": [
    {
      "include": ["**/*.config.*", "**/env.ts"],
      "linter": {
        "enabled": false
      }
    },
    {
      "include": ["apps/app/**/*.tsx", "apps/app/**/*.ts"],
      "linter": {
        "rules": {
          "a11y": {
            "useKeyWithClickEvents": "off",
            "useButtonType": "off",
            "noSvgWithoutTitle": "off",
            "useMediaCaption": "off",
            "noLabelWithoutControl": "off"
          },
          "suspicious": {
            "noExplicitAny": "error",
            "noArrayIndexKey": "off"
          },
          "correctness": {
            "useExhaustiveDependencies": "warn",
            "noUnusedFunctionParameters": "warn"
          }
        }
      }
    },
    {
      "include": [
        "apps/desktop/**/*.tsx",
        "apps/desktop/**/*.ts",
        "apps/desktop/**/*.js"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off",
            "noArrayIndexKey": "off"
          },
          "style": {
            "noNonNullAssertion": "off",
            "noInferrableTypes": "off",
            "useImportType": "off",
            "useExponentiationOperator": "off",
            "useTemplate": "off",
            "useNodejsImportProtocol": "off",
            "useNumberNamespace": "off",
            "useSelfClosingElements": "off",
            "noUnusedTemplateLiteral": "off"
          },
          "a11y": {
            "useButtonType": "off",
            "noSvgWithoutTitle": "off"
          },
          "correctness": {
            "noUnusedVariables": "off",
            "noUnusedImports": "off",
            "useExhaustiveDependencies": "off",
            "noUnusedFunctionParameters": "off"
          },
          "complexity": {
            "noUselessSwitchCase": "off",
            "noUselessConstructor": "off"
          }
        }
      }
    },
    {
      "include": ["apps/api/**/*.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off"
          },
          "style": {
            "noNonNullAssertion": "off",
            "noInferrableTypes": "off",
            "useTemplate": "off",
            "noUnusedTemplateLiteral": "off",
            "useExponentiationOperator": "off",
            "useImportType": "off"
          },
          "complexity": {
            "noUselessCatch": "off"
          }
        }
      }
    },
    {
      "include": ["**/*.css"],
      "css": {
        "parser": {
          "cssModules": false,
          "allowWrongLineComments": true
        }
      },
      "formatter": {
        "enabled": false
      },
      "linter": {
        "enabled": false
      }
    }
  ]
}
